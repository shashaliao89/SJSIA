PORT=4000

# 使用 docker compose up -d 後可直接套用此連線字串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sjsia_portal

JWT_SECRET=change-me-in-production-use-long-random-string

# 允許的前端來源（逗號分隔）。本機 Portal + 正式 Portal 網域
CORS_ORIGIN=http://localhost:3001,https://your-portal.vercel.app

# 預設管理員（db:seed 使用）
ADMIN_EMAIL=admin@sjsia.tw
ADMIN_PASSWORD=admin123456
